<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>商品別売上 昨対比較ツール</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  font-family: 'Hiragino Kaku Gothic ProN','Noto Sans JP','Meiryo',sans-serif;
  background: #f0fdf4; color: #1c1917; padding: 28px 20px; min-height: 100vh;
}
.container { max-width: 1100px; margin: 0 auto; }
.header { display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:22px; }
.header-label { font-size:11px; font-weight:700; color:#16a34a; letter-spacing:.15em; margin-bottom:3px; }
h1 { font-size:22px; font-weight:800; letter-spacing:-.02em; }
.label-inputs { display:flex; gap:8px; align-items:center; }
.label-inputs input { width:68px; padding:5px 10px; border:1.5px solid #e5e7eb; border-radius:8px; font-size:13px; text-align:center; background:#fff; }
.label-inputs input.current { border-color:#16a34a; color:#15803d; font-weight:700; background:#f0fdf4; }
.arrow { color:#d1d5db; font-size:18px; }

.toolbar { display:flex; justify-content:space-between; align-items:center; margin-bottom:16px; flex-wrap:wrap; gap:8px; }
.vtabs { display:flex; gap:4px; }
.vtab { padding:6px 14px; border-radius:8px; border:1.5px solid #e5e7eb; cursor:pointer; font-size:12px; font-weight:700; transition:all .15s; background:#fff; color:#9ca3af; }
.vtab.active { background:#1c1917; color:#fff; border-color:#1c1917; }

.metric-tabs { display:flex; gap:4px; }
.mtab { padding:6px 16px; border-radius:8px; border:none; cursor:pointer; font-size:13px; font-weight:700; transition:all .15s; background:#fff; color:#9ca3af; box-shadow:0 1px 3px rgba(0,0,0,.07); }
.mtab.active { background:#16a34a; color:#fff; box-shadow:0 2px 10px rgba(22,163,74,.3); }

.upload-card { background:#fff; border-radius:16px; padding:20px; box-shadow:0 1px 4px rgba(0,0,0,.06); margin-bottom:18px; border:1px solid #bbf7d0; }
.upload-hint { font-size:12px; color:#9ca3af; margin-bottom:14px; }
.upload-row { display:flex; gap:14px; }
.upload-col { flex:1; }
.upload-col label { font-size:13px; font-weight:700; color:#6b7280; display:block; margin-bottom:8px; }
.drop-zone {
  border:2px dashed #bbf7d0; border-radius:12px; padding:28px 16px; text-align:center;
  cursor:pointer; transition:all .15s; background:#f0fdf4; position:relative;
}
.drop-zone:hover, .drop-zone.dragover { border-color:#16a34a; background:#dcfce7; }
.drop-zone input[type=file] { position:absolute; inset:0; opacity:0; cursor:pointer; width:100%; }
.drop-icon { font-size:28px; margin-bottom:8px; }
.drop-text { font-size:13px; color:#6b7280; }
.drop-text strong { color:#16a34a; }
.upload-status { font-size:11px; color:#9ca3af; margin-top:8px; min-height:16px; }
.upload-status.ok { color:#16a34a; }
.upload-status.err { color:#dc2626; }

.options-row { display:flex; justify-content:flex-end; align-items:center; gap:12px; margin-top:12px; flex-wrap:wrap; }
.options-row label { font-size:12px; color:#9ca3af; }
.options-row select, .options-row input[type=text] { padding:4px 8px; border:1.5px solid #e5e7eb; border-radius:6px; font-size:13px; background:#f9fafb; }
.options-row input[type=text] { width:160px; }

.cards { display:flex; gap:12px; margin-bottom:18px; flex-wrap:wrap; }
.card { flex:1; min-width:140px; border-radius:12px; padding:14px 18px; }
.card-label { font-size:11px; color:#9ca3af; font-weight:700; letter-spacing:.08em; margin-bottom:4px; }
.card-value { font-size:20px; font-weight:800; }

.chart-card { background:#fff; border-radius:16px; padding:20px 16px 16px; box-shadow:0 1px 4px rgba(0,0,0,.06); margin-bottom:18px; border:1px solid #bbf7d0; }
.chart-title { font-size:13px; font-weight:700; color:#374151; margin-bottom:4px; }
.chart-sub { font-size:11px; color:#9ca3af; margin-bottom:14px; }
.chart-wrap { position:relative; height:320px; }

.table-card { background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,.06); border:1px solid #bbf7d0; margin-bottom:18px; }
.table-scroll { overflow-x:auto; }
table { width:100%; border-collapse:collapse; font-size:13px; min-width:700px; }
thead tr { background:#f0fdf4; border-bottom:2px solid #bbf7d0; }
th { padding:10px 14px; font-weight:700; color:#15803d; font-size:12px; letter-spacing:.04em; white-space:nowrap; text-align:left; }
th.num { text-align:right; }
th.sortable { cursor:pointer; user-select:none; }
th.sortable:hover { color:#16a34a; }
tbody tr { border-bottom:1px solid #f0fdf4; }
tbody tr:nth-child(even) { background:#f9fffe; }
tbody tr:hover { background:#dcfce7; }
td { padding:9px 14px; vertical-align:middle; }
td.num { text-align:right; }
td.rank { color:#d1d5db; font-weight:700; width:32px; text-align:center; }
td.lbl { font-weight:600; }
td.mgmt { font-size:11px; color:#9ca3af; }
td.curr-val { font-weight:700; color:#15803d; text-align:right; }
td.prev-val { color:#6b7280; text-align:right; }

.badge { display:inline-flex; align-items:center; gap:2px; padding:2px 8px; border-radius:999px; font-size:12px; font-weight:700; }
.badge.up { background:#d1fae5; color:#065f46; }
.badge.down { background:#fee2e2; color:#991b1b; }
.badge.none { color:#9ca3af; font-size:12px; }
.badge.gone { background:#f1f5f9; color:#475569; }

/* Disappeared */
.dis-card { background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 1px 4px rgba(0,0,0,.06); border:1px solid #e7e5e4; margin-bottom:18px; }
.dis-head { background:#1c1917; padding:16px 20px; }
.dis-head h3 { font-size:14px; font-weight:700; color:#fff; }
.dis-head p { font-size:12px; color:#a8a29e; margin-top:3px; }

.empty { background:#fff; border-radius:16px; padding:52px 24px; text-align:center; box-shadow:0 1px 4px rgba(0,0,0,.06); border:1px solid #bbf7d0; }
.empty-icon { font-size:40px; margin-bottom:14px; }
.empty-title { font-size:15px; font-weight:700; margin-bottom:8px; color:#44403c; }
.empty-sub { font-size:13px; color:#9ca3af; line-height:1.7; }
.hidden { display:none; }

.name-full { display:none; font-size:11px; color:#6b7280; margin-top:2px; line-height:1.4; max-width:400px; }
tr:hover .name-full { display:block; }
</style>
</head>
<body>
<div class="container">

  <div class="header">
    <div>
      <div class="header-label">楽天RMS ／ 商品別売上</div>
      <h1>商品別売上 昨対比較ツール</h1>
    </div>
    <div class="label-inputs">
      <input type="text" id="lastLabel" value="前年" oninput="refresh()" />
      <span class="arrow">→</span>
      <input type="text" id="thisLabel" value="今年" class="current" oninput="refresh()" />
    </div>
  </div>

  <div class="toolbar">
    <div class="metric-tabs">
      <button class="mtab active" onclick="switchMetric('sales')">💴 売上金額</button>
      <button class="mtab" onclick="switchMetric('qty')">📦 販売数量</button>
    </div>
    <div style="display:flex;gap:8px;align-items:center;">
      <button class="vtab" onclick="downloadCSV()" style="background:#f0fdf4;color:#15803d;border-color:#bbf7d0;">⬇ CSVダウンロード</button>
      <div class="vtabs">
        <button class="vtab active" id="vtab0" onclick="switchView(0)">📈 今年基準</button>
        <button class="vtab" id="vtab1" onclick="switchView(1)">🔍 消えた商品</button>
      </div>
    </div>
  </div>

  <!-- Upload card -->
  <div class="upload-card">
    <div class="upload-hint">📂 楽天RMSの「商品別売上CSV」をそのままアップロードしてください（ヘッダー行は自動でスキップします）</div>
    <div class="upload-row">
      <div class="upload-col">
        <label id="currUploadLabel">▶ 今年のCSV</label>
        <div class="drop-zone" id="currDrop">
          <input type="file" accept=".csv" onchange="loadCSV('curr', this.files[0])" />
          <div class="drop-icon">📄</div>
          <div class="drop-text"><strong>クリックまたはドロップ</strong><br>CSVファイルを選択</div>
        </div>
        <div class="upload-status" id="currStatus"></div>
      </div>
      <div class="upload-col">
        <label id="prevUploadLabel">▶ 前年のCSV</label>
        <div class="drop-zone" id="prevDrop">
          <input type="file" accept=".csv" onchange="loadCSV('prev', this.files[0])" />
          <div class="drop-icon">📄</div>
          <div class="drop-text"><strong>クリックまたはドロップ</strong><br>CSVファイルを選択</div>
        </div>
        <div class="upload-status" id="prevStatus"></div>
      </div>
    </div>
    <div class="options-row">
      <label>🔍 商品フィルタ：</label>
      <input type="text" id="filterInput" placeholder="キーワードで絞り込み" oninput="refresh()" />
      <label>表示件数：</label>
      <select id="topN" onchange="refresh()">
        <option value="10">上位10件</option>
        <option value="20">上位20件</option>
        <option value="30" selected>上位30件</option>
        <option value="50">上位50件</option>
        <option value="100">上位100件</option>
        <option value="999">全件</option>
      </select>
    </div>
  </div>

  <!-- View A -->
  <div id="viewA">
    <div class="cards hidden" id="cards">
      <div class="card" style="background:#f0fdf4;border:1.5px solid #bbf7d0;">
        <div class="card-label" id="cardCurrLabel">今年 売上合計</div>
        <div class="card-value" style="color:#15803d;" id="cardCurr">―</div>
      </div>
      <div class="card" style="background:#f9fafb;border:1.5px solid #e5e7eb;">
        <div class="card-label" id="cardPrevLabel">前年 売上合計</div>
        <div class="card-value" style="color:#6b7280;" id="cardPrev">―</div>
      </div>
      <div class="card" id="cardYoyCard" style="background:#f9fafb;border:1.5px solid #e5e7eb;">
        <div class="card-label">昨対比（合計）</div>
        <div class="card-value" id="cardYoy">―</div>
      </div>
      <div class="card" style="background:#fff7ed;border:1.5px solid #fed7aa;">
        <div class="card-label" id="cardItemsLabel">商品数</div>
        <div class="card-value" style="color:#c2410c;" id="cardItems">―</div>
      </div>
    </div>

    <div class="chart-card hidden" id="chartCard">
      <div class="chart-title" id="chartTitle">商品別 売上金額 比較</div>
      <div class="chart-sub">ホバーで商品名全文表示</div>
      <div class="chart-wrap"><canvas id="myChart"></canvas></div>
    </div>

    <div class="table-card hidden" id="tableCard">
      <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>商品管理番号</th>
            <th>商品名</th>
            <th class="num sortable" onclick="sortBy('curr')" id="thCurr">今年 ▼</th>
            <th class="num sortable" onclick="sortBy('prev')" id="thPrev">前年</th>
            <th class="num">昨対</th>
            <th class="num sortable" onclick="sortBy('diff')" id="thDiff">増減</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
      </div>
    </div>

    <div class="empty" id="emptyCard">
      <div class="empty-icon">📊</div>
      <div class="empty-title">CSVをアップロードしてください</div>
      <div class="empty-sub">楽天RMSの商品別売上CSVを<br>今年・前年それぞれアップロードすると比較が表示されます</div>
    </div>
  </div>

  <!-- View B: 消えた商品 -->
  <div id="viewB" class="hidden">
    <div class="dis-card" id="disCard">
      <div class="dis-head">
        <h3 id="disTitle">🔍 前年に売れていたが今年に消えた・大幅減した商品</h3>
        <p id="disSubtitle">前年の売上を基準に降順表示。今年の売上がゼロの商品は「消滅」として表示します。</p>
      </div>
      <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>商品管理番号</th>
            <th>商品名</th>
            <th class="num" id="disPrevLbl">前年</th>
            <th class="num" id="disCurrLbl">今年</th>
            <th class="num">昨対</th>
            <th class="num">増減</th>
            <th class="num">状態</th>
          </tr>
        </thead>
        <tbody id="disBody"></tbody>
      </table>
      </div>
    </div>
    <div class="empty" id="disEmpty">
      <div class="empty-icon">🔍</div>
      <div class="empty-title">両年のCSVをアップロードしてください</div>
      <div class="empty-sub">今年・前年両方のデータがあると消えた商品を検出できます</div>
    </div>
  </div>

</div>

<script>
let parsedData = { curr: null, prev: null };
let activeMetric = 'sales'; // 'sales' or 'qty'
let activeView = 0;
let sortKey = 'curr';
let chartInstance = null;

// --- CSV Parser ---
function parseCSV(text) {
  // Detect encoding issues and normalize line endings
  const lines = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').split('\n');
  
  // Find header row (contains 商品名,商品管理番号,...)
  let headerIdx = -1;
  for (let i = 0; i < lines.length; i++) {
    if (lines[i].includes('商品名') && lines[i].includes('売上個数')) {
      headerIdx = i;
      break;
    }
  }
  if (headerIdx === -1) return null;

  const headers = parseCSVRow(lines[headerIdx]);
  const idxName    = headers.indexOf('商品名');
  const idxMgmt   = headers.indexOf('商品管理番号');
  const idxSales  = headers.indexOf('売上');
  const idxQty    = headers.indexOf('売上個数');
  const idxOrders = headers.indexOf('売上件数');
  const idxPrice  = headers.indexOf('平均単価');

  const rows = [];
  for (let i = headerIdx + 1; i < lines.length; i++) {
    const line = lines[i].trim();
    if (!line) continue;
    const cols = parseCSVRow(line);
    if (cols.length < 4) continue;
    const name  = cols[idxName]  || '';
    const mgmt  = cols[idxMgmt]  || '';
    const sales = parseInt((cols[idxSales] || '0').replace(/,/g, ''), 10) || 0;
    const qty   = parseInt((cols[idxQty]   || '0').replace(/,/g, ''), 10) || 0;
    if (!name && !mgmt) continue;
    rows.push({ name, mgmt, sales, qty });
  }
  return rows;
}

function parseCSVRow(line) {
  const result = [];
  let inQuote = false, cur = '';
  for (let i = 0; i < line.length; i++) {
    const c = line[i];
    if (c === '"') {
      if (inQuote && line[i+1] === '"') { cur += '"'; i++; }
      else inQuote = !inQuote;
    } else if (c === ',' && !inQuote) {
      result.push(cur.trim()); cur = '';
    } else { cur += c; }
  }
  result.push(cur.trim());
  return result;
}

function shortName(name) {
  // Extract meaningful short name: take first【】content or first ~15 chars before space
  const m = name.match(/【([^】]+)】/);
  if (m) return m[1];
  // Try to get product type from name
  return name.replace(/[【】「」\s]/g, ' ').trim().slice(0, 25);
}

// --- File Load ---
function loadCSV(which, file) {
  if (!file) return;
  const reader = new FileReader();
  reader.onload = e => {
    // Try UTF-8 first, then Shift-JIS via TextDecoder
    let text = e.target.result;
    const rows = parseCSV(text);
    if (!rows || rows.length === 0) {
      document.getElementById(which + 'Status').textContent = '❌ 読み込み失敗：CSVの形式を確認してください';
      document.getElementById(which + 'Status').className = 'upload-status err';
      return;
    }
    parsedData[which] = rows;
    const totalSales = rows.reduce((s, r) => s + r.sales, 0);
    document.getElementById(which + 'Status').textContent =
      `✅ ${rows.length}商品・売上合計 ¥${totalSales.toLocaleString()} 読み込み完了`;
    document.getElementById(which + 'Status').className = 'upload-status ok';
    // Update drop zone UI
    const zone = document.getElementById(which + 'Drop');
    zone.style.borderColor = '#16a34a';
    zone.style.background = '#dcfce7';
    zone.querySelector('.drop-text').innerHTML = `<strong style="color:#15803d">✅ ${file.name}</strong><br>${rows.length}商品`;
    refresh();
  };
  reader.readAsText(file, 'UTF-8');
}

// --- Metric & View ---
function switchMetric(m) {
  activeMetric = m;
  document.querySelectorAll('.mtab').forEach((t, i) => t.classList.toggle('active', (i===0&&m==='sales')||(i===1&&m==='qty')));
  refresh();
}
function switchView(i) {
  activeView = i;
  document.getElementById('vtab0').classList.toggle('active', i===0);
  document.getElementById('vtab1').classList.toggle('active', i===1);
  document.getElementById('viewA').classList.toggle('hidden', i!==0);
  document.getElementById('viewB').classList.toggle('hidden', i!==1);
  refresh();
}
function sortBy(key) {
  sortKey = key;
  document.querySelectorAll('th.sortable').forEach(th => {
    th.textContent = th.textContent.replace(' ▼','').replace(' ▲','');
  });
  const el = document.getElementById('th' + key.charAt(0).toUpperCase() + key.slice(1));
  if (el) el.textContent += ' ▼';
  refresh();
}

function calcChange(curr, prev) {
  if (!prev || prev === 0) return null;
  return ((curr - prev) / prev * 100).toFixed(1);
}
function badge(pct) {
  if (pct === null) return '<span class="badge none">―</span>';
  const n = parseFloat(pct), cls = n>=0?'up':'down', arrow = n>=0?'▲':'▼';
  return `<span class="badge ${cls}">${arrow} ${Math.abs(n)}%</span>`;
}
function yen(n) { return n > 0 ? '¥' + n.toLocaleString() : '<span style="color:#d1d5db">―</span>'; }
function num(n) { return n > 0 ? n.toLocaleString() : '<span style="color:#d1d5db">―</span>'; }
function fmtVal(n) { return activeMetric === 'sales' ? yen(n) : num(n); }

// --- CSV Download ---
function downloadCSV() {
  const thisLbl = document.getElementById('thisLabel').value || '今年';
  const lastLbl = document.getElementById('lastLabel').value || '前年';
  const metricLabel = activeMetric === 'sales' ? '売上金額' : '販売数量';
  const curr = parsedData.curr;
  const prev = parsedData.prev;
  if (!curr && !prev) { alert('先にCSVをアップロードしてください'); return; }

  const map = {};
  (curr || []).forEach(r => {
    const key = r.mgmt || r.name;
    map[key] = { name: r.name, mgmt: r.mgmt, curr: r[activeMetric==='sales'?'sales':'qty'], prev: 0 };
  });
  (prev || []).forEach(r => {
    const key = r.mgmt || r.name;
    if (map[key]) map[key].prev = r[activeMetric==='sales'?'sales':'qty'];
    else map[key] = { name: r.name, mgmt: r.mgmt, curr: 0, prev: r[activeMetric==='sales'?'sales':'qty'] };
  });

  const filter = document.getElementById('filterInput').value.toLowerCase();
  let rows = Object.values(map);
  if (filter) rows = rows.filter(r => r.name.toLowerCase().includes(filter) || r.mgmt.toLowerCase().includes(filter));

  const viewLabel = activeView === 0 ? '今年基準' : '消えた商品';
  if (activeView === 0) {
    rows.sort((a, b) => b.curr - a.curr);
  } else {
    rows = rows.filter(r => r.prev > 0).sort((a, b) => b.prev - a.prev);
  }

  const escCSV = v => `"${String(v).replace(/"/g, '""')}"`;

  const header = ['#', '商品管理番号', '商品名', `${thisLbl}_${metricLabel}`, `${lastLbl}_${metricLabel}`, '昨対(%)', '増減', '状態'];
  const dataRows = rows.map((row, i) => {
    const pct = (row.curr > 0 && row.prev > 0) ? ((row.curr - row.prev) / row.prev * 100).toFixed(1) : (row.curr === 0 && row.prev > 0 ? '-100.0' : '');
    const diff = row.curr - row.prev;
    let status = '';
    if (activeView === 1) {
      if (row.curr === 0) status = '消滅';
      else if (parseFloat(pct) >= 0) status = '増加';
      else if (parseFloat(pct) >= -20) status = '横ばい';
      else status = '大幅減';
    }
    return [i+1, escCSV(row.mgmt), escCSV(row.name), row.curr, row.prev, pct, diff, escCSV(status)].join(',');
  });

  const bom = '\uFEFF';
  const csv = bom + [header.join(','), ...dataRows].join('\n');
  const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `商品別比較_${viewLabel}_${metricLabel}_${new Date().toISOString().slice(0,10)}.csv`;
  a.click();
  URL.revokeObjectURL(url);
}

function refresh() {
  const thisLbl = document.getElementById('thisLabel').value || '今年';
  const lastLbl = document.getElementById('lastLabel').value || '前年';
  const topN = parseInt(document.getElementById('topN').value);
  const filter = document.getElementById('filterInput').value.toLowerCase();
  const metricLabel = activeMetric === 'sales' ? '売上金額' : '販売数量';
  const metricUnit = activeMetric === 'sales' ? '¥' : '';

  // Update UI labels
  document.getElementById('currUploadLabel').textContent = `▶ ${thisLbl}のCSV`;
  document.getElementById('prevUploadLabel').textContent = `▶ ${lastLbl}のCSV`;
  document.getElementById('cardCurrLabel').textContent = `${thisLbl} ${metricLabel}合計`;
  document.getElementById('cardPrevLabel').textContent = `${lastLbl} ${metricLabel}合計`;
  document.getElementById('chartTitle').textContent = `商品別 ${metricLabel} 比較（上位${topN}件）`;
  document.getElementById('thCurr').innerHTML = `${thisLbl} <span style="color:#aaa">▼</span>`;
  document.getElementById('thPrev').textContent = lastLbl;
  document.getElementById('disPrevLbl').textContent = lastLbl;
  document.getElementById('disCurrLbl').textContent = thisLbl;
  document.getElementById('disTitle').textContent = `🔍 ${lastLbl}に売れていたが${thisLbl}に消えた・大幅減した商品`;
  document.getElementById('disSubtitle').textContent = `${lastLbl}の${metricLabel}を基準に降順表示。${thisLbl}がゼロの商品は「消滅」として表示。`;

  const curr = parsedData.curr;
  const prev = parsedData.prev;
  const hasData = curr || prev;
  const hasBoth = curr && prev;

  // Merge
  const map = {};
  (curr || []).forEach(r => {
    const key = r.mgmt || r.name;
    map[key] = { name: r.name, mgmt: r.mgmt, curr: r[activeMetric === 'sales' ? 'sales' : 'qty'], prev: 0 };
  });
  (prev || []).forEach(r => {
    const key = r.mgmt || r.name;
    if (map[key]) map[key].prev = r[activeMetric === 'sales' ? 'sales' : 'qty'];
    else map[key] = { name: r.name, mgmt: r.mgmt, curr: 0, prev: r[activeMetric === 'sales' ? 'sales' : 'qty'] };
  });

  let allMerged = Object.values(map);
  // Apply filter
  if (filter) {
    allMerged = allMerged.filter(r =>
      r.name.toLowerCase().includes(filter) || r.mgmt.toLowerCase().includes(filter)
    );
  }

  // ---- VIEW A ----
  if (activeView === 0) {
    document.getElementById('emptyCard').classList.toggle('hidden', !!hasData);
    document.getElementById('cards').classList.toggle('hidden', !hasData);
    document.getElementById('chartCard').classList.toggle('hidden', !hasData);
    document.getElementById('tableCard').classList.toggle('hidden', !hasData);
    if (!hasData) return;

    // Sort
    let sorted = [...allMerged];
    if (sortKey === 'curr') sorted.sort((a,b) => b.curr - a.curr);
    else if (sortKey === 'prev') sorted.sort((a,b) => b.prev - a.prev);
    else if (sortKey === 'diff') sorted.sort((a,b) => (b.curr-b.prev) - (a.curr-a.prev));
    const merged = sorted.slice(0, topN);

    // Summary
    const totalCurr = (curr||[]).reduce((s,r) => s + r[activeMetric==='sales'?'sales':'qty'], 0);
    const totalPrev = (prev||[]).reduce((s,r) => s + r[activeMetric==='sales'?'sales':'qty'], 0);
    const totalPct = calcChange(totalCurr, totalPrev);
    const tpn = totalPct !== null ? parseFloat(totalPct) : null;
    const totalItems = new Set([...(curr||[]).map(r=>r.mgmt), ...(prev||[]).map(r=>r.mgmt)]).size;

    document.getElementById('cardCurr').textContent = activeMetric==='sales' ? '¥'+totalCurr.toLocaleString() : totalCurr.toLocaleString();
    document.getElementById('cardPrev').textContent = totalPrev ? (activeMetric==='sales'?'¥':'')+totalPrev.toLocaleString() : '―';
    document.getElementById('cardItems').textContent = totalItems + '商品';
    document.getElementById('cardItemsLabel').textContent = filter ? '絞り込み結果' : '商品数';

    const yoyEl = document.getElementById('cardYoy'), yoyCard = document.getElementById('cardYoyCard');
    if (tpn !== null) {
      yoyEl.textContent = `${tpn>=0?'▲':'▼'} ${Math.abs(tpn)}%`;
      yoyEl.style.color = tpn>=0 ? '#065f46' : '#991b1b';
      yoyCard.style.background = tpn>=0 ? '#ecfdf5' : '#fef2f2';
      yoyCard.style.border = `1.5px solid ${tpn>=0?'#a7f3d0':'#fecaca'}`;
    } else { yoyEl.textContent='―'; yoyEl.style.color='#9ca3af'; }

    // Chart (top 20 for readability)
    const chartData = merged.slice(0, 20);
    if (chartInstance) chartInstance.destroy();
    chartInstance = new Chart(document.getElementById('myChart').getContext('2d'), {
      type: 'bar',
      data: {
        labels: chartData.map(r => r.mgmt || shortName(r.name)),
        datasets: [
          { label: lastLbl, data: chartData.map(r => r.prev), backgroundColor: '#d1d5db', borderRadius: 3 },
          { label: thisLbl, data: chartData.map(r => r.curr), backgroundColor: '#16a34a', borderRadius: 3 }
        ]
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        plugins: {
          legend: { labels: { font: { size: 12 } } },
          tooltip: {
            callbacks: {
              title: (items) => {
                const idx = items[0].dataIndex;
                return chartData[idx].name.slice(0, 60) + (chartData[idx].name.length > 60 ? '...' : '');
              },
              label: (item) => {
                const val = item.raw;
                return ` ${item.dataset.label}: ${activeMetric==='sales'?'¥':''}${val.toLocaleString()}`;
              }
            }
          }
        },
        scales: {
          x: { ticks: { font: { size: 10 }, maxRotation: 40, minRotation: 30 }, grid: { color: '#f3f4f6' } },
          y: { ticks: { font: { size: 11 }, callback: v => activeMetric==='sales' ? (v>=10000?'¥'+Math.round(v/10000)+'万':'¥'+v) : v>=1000?Math.round(v/1000)+'k':v }, grid: { color: '#f3f4f6' } }
        }
      }
    });

    // Table
    document.getElementById('tableBody').innerHTML = merged.map((row, i) => {
      const pct = (row.curr > 0 && row.prev > 0) ? calcChange(row.curr, row.prev) : null;
      const diff = row.curr - row.prev;
      const bothExist = row.curr > 0 && row.prev > 0;
      const diffStr = bothExist
        ? `<span style="color:${diff>=0?'#059669':'#dc2626'}">${diff>=0?'+':''}${activeMetric==='sales'?'¥':''}${diff.toLocaleString()}</span>`
        : '<span style="color:#d1d5db">―</span>';
      const bg = i%2===0 ? '#fff' : '#f9fffe';
      const shortN = shortName(row.name);
      return `<tr style="background:${bg}" title="${row.name}">
        <td class="rank">${i+1}</td>
        <td class="mgmt">${row.mgmt}</td>
        <td class="lbl">
          <div>${shortN}</div>
          <div class="name-full">${row.name}</div>
        </td>
        <td class="curr-val">${fmtVal(row.curr)}</td>
        <td class="prev-val">${fmtVal(row.prev)}</td>
        <td class="num">${badge(pct)}</td>
        <td class="num">${diffStr}</td>
      </tr>`;
    }).join('');
  }

  // ---- VIEW B: 消えた商品 ----
  if (activeView === 1) {
    document.getElementById('disEmpty').classList.toggle('hidden', hasBoth);
    document.getElementById('disCard').classList.toggle('hidden', !hasBoth);
    if (!hasBoth) return;

    const disappeared = [...allMerged]
      .filter(r => r.prev > 0)
      .sort((a, b) => b.prev - a.prev)
      .slice(0, topN);

    document.getElementById('disBody').innerHTML = disappeared.map((row, i) => {
      const pct = row.curr > 0 ? calcChange(row.curr, row.prev) : null;
      const pctGone = calcChange(0, row.prev); // -100% for gone
      const diff = row.curr - row.prev;
      let statusBadge;
      if (row.curr === 0) {
        statusBadge = '<span class="badge gone">消滅</span>';
      } else {
        const n = parseFloat(pct);
        if (n >= 0) statusBadge = '<span class="badge up">▲ 増加</span>';
        else if (n >= -20) statusBadge = '<span class="badge" style="background:#fef9c3;color:#854d0e">横ばい</span>';
        else statusBadge = '<span class="badge down">▼ 大幅減</span>';
      }
      const yoyBadge = row.curr === 0
        ? '<span class="badge down">▼ 100%</span>'
        : badge(pct);
      const diffStr = row.curr > 0
        ? `<span style="color:${diff>=0?'#059669':'#dc2626'}">${diff>=0?'+':''}${activeMetric==='sales'?'¥':''}${diff.toLocaleString()}</span>`
        : `<span style="color:#dc2626">-${activeMetric==='sales'?'¥':''}${row.prev.toLocaleString()}</span>`;
      const bg = i%2===0 ? '#fff' : '#fafaf9';
      return `<tr style="background:${bg}" title="${row.name}">
        <td class="rank">${i+1}</td>
        <td class="mgmt">${row.mgmt}</td>
        <td class="lbl">
          <div>${shortName(row.name)}</div>
          <div class="name-full">${row.name}</div>
        </td>
        <td class="num" style="color:#6b7280;">${activeMetric==='sales'?'¥':''}${row.prev.toLocaleString()}</td>
        <td class="num" style="color:${row.curr>0?'#15803d':'#d1d5db'};">${row.curr>0?(activeMetric==='sales'?'¥':'')+row.curr.toLocaleString():'ランク外'}</td>
        <td class="num">${yoyBadge}</td>
        <td class="num">${diffStr}</td>
        <td class="num">${statusBadge}</td>
      </tr>`;
    }).join('');
  }
}

refresh();
</script>
</body>
</html>
